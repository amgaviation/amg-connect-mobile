{
  "expo": {
    "name": "AMG Connect",
    "slug": "amg-connect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/amg-icon-placeholder.png",
    "scheme": "amgconnect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.amgaviationgroup.connect",
      "icon": "./assets/icons/amg-icon-placeholder.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.amgaviationgroup.connect",
      "adaptiveIcon": {
        "backgroundColor": "#050B14",
        "foregroundImage": "./assets/icons/amg-icon-placeholder.png",
        "monochromeImage": "./assets/icons/amg-icon-placeholder.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 4
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/amg-icon-placeholder.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050B14",
          "image": "./assets/logo/amg-logo-white.png",
          "imageWidth": 220,
          "android": {
            "image": "./assets/logo/amg-logo-white.png",
            "imageWidth": 220
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f595136d-8b86-49c2-8478-8c171f37208f"
      }
    },
    "owner": "amgaviations-team"
  }
}
