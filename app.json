{
  "expo": {
    "name": "AMG Connect",
    "slug": "amg-connect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/amg-logo-white.png",
    "scheme": "amgconnect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.amgaviationgroup.connect",
      "icon": "./assets/logo/amg-logo-white.png"
    },
    "android": {
      "package": "com.amgaviationgroup.connect",
      "adaptiveIcon": {
        "backgroundColor": "#050B14",
        "foregroundImage": "./assets/logo/amg-logo-white.png",
        "monochromeImage": "./assets/logo/amg-logo-white.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/amg-logo-white.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050B14",
          "image": "./assets/logo/amg-logo-white.png",
          "imageWidth": 220,
          "android": {
            "image": "./assets/logo/amg-logo-white.png",
            "imageWidth": 220
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
